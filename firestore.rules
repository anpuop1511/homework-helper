rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // 1) Usernames — claim/release only for the owning user
    match /usernames/{handle} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // 2) User profiles + subcollections
    match /users/{uid} {
      allow read: if signedIn();
      allow create, delete: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid;

      // Friends sub-collection.
      // Both the profile owner (uid) AND the friend being added (friendUid)
      // may write their own entry so that the accept-request batch can
      // commit both sides atomically in a single Firestore batch.
      match /friends/{friendUid} {
        allow read: if signedIn() &&
          (request.auth.uid == uid || request.auth.uid == friendUid);
        allow write: if signedIn() &&
          (request.auth.uid == uid || request.auth.uid == friendUid);
      }

      // Incoming friend-request notification copies (per-user subcollection).
      match /friendRequests/{requestId} {
        allow read: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn() &&
          request.resource.data.fromUid == request.auth.uid;
        allow delete: if signedIn() &&
          (request.auth.uid == uid ||
           request.auth.uid == resource.data.fromUid);
      }

      // All other private subcollections (assignments, settings, etc.) —
      // owner-only access.
      match /{subDoc=**} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    // 3) Global friend-request documents
    match /friend_requests/{requestId} {
      allow read: if signedIn() &&
        (request.auth.uid == resource.data.from ||
         request.auth.uid == resource.data.to);

      allow create: if signedIn() &&
        request.resource.data.from == request.auth.uid &&
        request.resource.data.to is string &&
        request.resource.data.from != request.resource.data.to;

      allow update, delete: if signedIn() &&
        (request.auth.uid == resource.data.from ||
         request.auth.uid == resource.data.to);
    }

    // 4) Group Projects
    match /projects/{projectId} {
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;

      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids is list
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;

      allow update, delete: if signedIn() &&
        resource.data.ownerUid == request.auth.uid;
    }

    // 5) Project bulletins (members only)
    match /projects/{projectId}/bulletins/{bulletinId} {
      allow read, create: if signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberUids;

      allow update, delete: if signedIn() &&
        resource.data.authorUid == request.auth.uid;
    }

    // 6) Project tasks (members only)
    match /projects/{projectId}/tasks/{taskId} {
      allow read, create, update, delete: if signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberUids;
    }
  }
}
